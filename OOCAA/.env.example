# MATLAB Configuration
# Copy this file to .env and update with your local paths

# Path to the CARA Analysis Tools distributed MATLAB directory
# Example (Windows): C:\Users\YourName\OneDrive\Desktop\Capstone\CARA_Analysis_Tools\DistributedMatlab
# Example (Mac/Linux): /Users/YourName/Capstone/CARA_Analysis_Tools/DistributedMatlab
CARA_MATLAB_PATH=

# Optional: MATLAB installation directory (if needed for engine setup)
# Example (Windows): C:\Program Files\MATLAB\R2025b
# Example (Mac): /Applications/MATLAB_R2025b.app
MATLAB_ROOT=

# Email Configuration for Gmail CDM Ingestion
# This feature automatically monitors your Gmail inbox for CDM JSON attachments
# and ingests them into the database.
#
# Setup Instructions:
#   1. Enable 2-step verification: https://myaccount.google.com/security
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Select "Mail" and "Windows Computer"
#   4. Copy the 16-digit password Google provides
#   5. Paste it into EMAIL_PASSWORD below
#
# To disable email ingestion: Leave EMAIL_PASSWORD empty

EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_USERNAME=automatedcsatest@gmail.com

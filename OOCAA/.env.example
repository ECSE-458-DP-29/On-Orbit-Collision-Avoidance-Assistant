# OOCAA Environment Variables Template
# Copy this file to .env and fill in your values

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (if using PostgreSQL)
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=oocaa_db
# DATABASE_USER=your_db_user
# DATABASE_PASSWORD=your_db_password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# MongoDB Configuration (if using MongoDB)
# MONGODB_ENGINE=djongo
# MONGODB_NAME=oocaa_database
# MONGODB_HOST=your_mongodb_connection_string

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# API Settings
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

# Email Configuration (for notifications)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password

# External APIs (for future integrations)
# SPACE_TRACK_USERNAME=your_username
# SPACE_TRACK_PASSWORD=your_password

# Logging
LOG_LEVEL=INFO
